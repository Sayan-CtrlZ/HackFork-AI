# HackFork Environment Variables — Example
# Copy this file to .env and fill in your actual keys
# The .env file is gitignored — safe to put real keys there

# Google Gemini (get free key at aistudio.google.com)
GOOGLE_AI_API_KEY=your-gemini-key-here

# Anthropic Claude (optional)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional)
# OPENAI_API_KEY=sk-...
